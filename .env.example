# ── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=generate_a_very_long_random_string_here
DEBUG=False
ALLOWED_HOSTS=your-machine-name.tailnet-1234.ts.net,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://playtopay-frontend.vercel.app,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://playtopay-frontend.vercel.app

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_DB=playtopay
POSTGRES_USER=playtopay
POSTGRES_PASSWORD=super_secret_db_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis (Celery & Caching) ──────────────────────────────────────────────────
# The URL is dynamically built in compose, but you MUST set the password
REDIS_PASSWORD=super_secret_redis_password

# ── Security & SSL ────────────────────────────────────────────────────────────
# Set to False ONLY if testing locally without HTTPS. Keep True for Vercel/Tailscale
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ── Gunicorn / Startup Tuning ─────────────────────────────────────────────────
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
SEED_DEMO_DATA_ON_START=false

# ── Application Specific ──────────────────────────────────────────────────────
IDEMPOTENCY_KEY_EXPIRY_HOURS=24

# ── Observability (Optional) ──────────────────────────────────────────────────
SENTRY_DSN=
